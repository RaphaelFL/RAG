{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ChatModelOptions": {
    "Model": "gpt-4.1",
    "Deployment": "",
    "Temperature": 0.7,
    "MaxTokens": 2000,
    "TopP": 0.95
  },
  "EmbeddingOptions": {
    "Model": "text-embedding-3-small",
    "Deployment": "",
    "Dimensions": 1536,
    "BatchSize": 100
  },
  "SearchOptions": {
    "IndexName": "chatbot-documents",
    "SemanticConfigurationName": "default",
    "HybridSearchWeight": 0.5,
    "SemanticRankingEnabled": true,
    "TopK": 10
  },
  "BlobStorageOptions": {
    "ConnectionString": "",
    "ContainerName": "documents"
  },
  "OcrOptions": {
    "PrimaryProvider": "AzureDocumentIntelligence",
    "FallbackProvider": "GoogleVision",
    "AzureDocumentIntelligenceModelId": "prebuilt-read",
    "EnableFallback": true
  },
  "PromptTemplateOptions": {
    "GroundedAnswerVersion": "1.0.0",
    "DefaultTimeout": 30,
    "InsufficientEvidenceMessage": "Nao encontrei evidencia documental suficiente para responder com seguranca a partir da base indexada.",
    "BlockedInputPatterns": [
      "ignore previous instructions",
      "disregard previous instructions",
      "system prompt",
      "developer message",
      "execute tool",
      "reveal secret"
    ]
  },
  "FeatureFlagOptions": {
    "EnableSemanticRanking": true,
    "EnableMcp": false,
    "EnableGraphRag": false,
    "EnableRedisCache": false
  },
  "ExternalProviderClientOptions": {
    "TimeoutSeconds": 30,
    "AzureOpenAiBaseUrl": "",
    "AzureOpenAiApiKey": "",
    "AzureOpenAiApiVersion": "2024-10-21",
    "AzureOpenAiChatDeployment": "",
    "AzureOpenAiEmbeddingDeployment": "",
    "AzureSearchBaseUrl": "",
    "AzureSearchApiKey": "",
    "AzureSearchApiVersion": "2024-07-01",
    "BlobStorageBaseUrl": "",
    "AzureDocumentIntelligenceBaseUrl": "",
    "AzureDocumentIntelligenceApiKey": "",
    "AzureDocumentIntelligenceApiVersion": "2024-11-30",
    "GoogleVisionBaseUrl": "https://vision.googleapis.com/",
    "GoogleVisionApiKey": ""
  }
}
